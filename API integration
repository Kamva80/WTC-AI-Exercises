from api_client import fetch_product_price

def update_prices_from_api(items: List[Item]) -> List[Item]:
    """Updates item prices by fetching live data from API.

    Args:
        items: List of items with 'name' key.

    Returns:
        List[Item]: Items with updated 'price' from API. Falls back to old price if API fails.
    """
    for item in items:
        live_price = fetch_product_price(item['name'])
        if live_price is not None:
            print(f"Updated {item['name']} price to ${live_price}")
            item['price'] = live_price
        else:
            print(f"Could not update {item['name']}. Using old price.")
    return items

