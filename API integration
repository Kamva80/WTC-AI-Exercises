"""
api_client.py

Handles all external API calls for the inventory system.
"""

import requests
import os
from typing import Dict, Optional

API_BASE_URL = "https://fakestoreapi.com" # Free public API, no key needed

def fetch_product_price(product_name: str) -> Optional[float]:
    """Fetches live product price from external API.

    Args:
        product_name: Name of product to search for.

    Returns:
        float: Product price if found, None if API fails or product not found.

    Raises:
        requests.RequestException: If network request fails.
    """
    try:
        # FakeStoreAPI doesn't have search, so we get all and filter
        response = requests.get(f"{API_BASE_URL}/products")
        response.raise_for_status() # Raises error for 4xx/5xx
        products = response.json()

        for product in products:
            if product_name.lower() in product['title'].lower():
                return float(product['price'])
        return None

    except requests.RequestException as e:
        print(f"API Error: Could not fetch price. {e}")
        return None
    except (KeyError, ValueError) as e:
        print(f"Data Error: Invalid API response. {e}")
        return None

